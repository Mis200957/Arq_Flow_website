      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "typeValidation": "loose"
          },
          "combinator": "and",
          "conditions": [
            {
              "id": "e5cd7996-5e0c-426f-b952-bad158724652",
              "leftValue": "={{ !!$json.target_wf_id }}",
              "rightValue": "",
              "operator": {
                "type": "boolean",
                "operation": "true",
