      "typeVersion": 4.2,
      "position": [
        440,
        0
      ],
      "credentials": {
        "supabaseApi": {
          "id": "arqflow_supabase",
          "name": "Supabase service_role"
        }
      },
      "alwaysOutputData": true,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const cfg=$('CONFIG').first().json.cfg;\nconst rows=$('FETCH_PENDING').first().json;\nconst list=Array.isArray(rows)?rows:[];\nconst out=[];\nfor(const r of list){\n  const target=cfg[r.workflow];\n  // Always mark processed (even unmapped) to avoid re-polling; mapped ones dispatch.\n  const payload=Object.assign({business_id:r.business_id,_log_id:r.id,_workflow:r.workflow,target_wf_id:target||''},(r.payload&&typeof r.payload==='object')?r.payload:{});\n  out.push({json:payload});\n}\nreturn out;"
      },
      "id": "7751e05f-2166-47ab-a663-221da5e3d7bc",
      "name": "ROUTE",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
