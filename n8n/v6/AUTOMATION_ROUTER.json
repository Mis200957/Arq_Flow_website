        "jsCode": "// ⚙️ EDIT ONCE: map automation workflows -> imported sub-workflow IDs.\nconst cfg={\n  notify:'SET_SHARED_NOTIFY_DISPATCH_ID', usage_threshold:'SET_SHARED_NOTIFY_DISPATCH_ID',\n  regenerate_system_prompt:'SET_SHARED_GENERATE_PROMPT_ID',\n  kb_rebuild:'SET_SHARED_REBUILD_KNOWLEDGE_ID', ai_retrain:'SET_SHARED_REBUILD_KNOWLEDGE_ID',\n  kb_file_process:'SET_SHARED_PROCESS_DOCUMENT_ID', subscription_request:null, ai_restart_context:null, bot_config_sync:null\n};\nreturn {json:{cfg}};"
      },
      "id": "ad53c3c1-5c26-44b7-9c10-fa5d7f4710dc",
      "name": "CONFIG",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        220,
        0
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://zjathejcdkpxjyvululp.supabase.co/rest/v1/automation_logs?select=id,business_id,workflow,event,payload&processed_at=is.null&order=created_at.asc&limit=25",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "supabaseApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "options": {}
      },
      "id": "906e309a-3acc-4664-81a6-2281102ee55d",
      "name": "FETCH_PENDING",
