    {
      "parameters": {
        "jsCode": "const ai = $input.first().json;\nlet reply = '';\nif (typeof ai.output === 'string') reply = ai.output;\nelse if (ai.text) reply = ai.text;\nelse if (ai.output && ai.output[0] && ai.output[0].content && ai.output[0].content[0]) reply = ai.output[0].content[0].text || '';\nelse if (ai.choices && ai.choices[0]) reply = ai.choices[0].message.content || '';\nreply = String(reply).trim();\nconst p = $('PARSE_MESSAGE').first().json;\nconst cfg = $('TENANT_CONFIG').first().json;\nconst sys = cfg.system_prompt || '';\nconst input_tokens = Math.ceil((sys.length + (p.customer_message || '').length) / 4);\nconst output_tokens = Math.ceil(reply.length / 4);\nreturn { json: {\n  reply, phone: p.phone, name: p.name, customer_message: p.customer_message,\n  wa_message_id: p.wa_message_id, input_tokens, output_tokens,\n  instance_name: cfg.instance_name, business_id: cfg.business_id,\n  plan_id: cfg.plan_id, model: cfg.model\n} };"
      },
