    {
      "parameters": {
        "jsCode": "const e = $('EXTRACT_REPLY').first().json;\nlet cost = 0; try { const r = $('CALCULATE_COST').first().json; cost = (r && r.cost_egp) || 0; } catch (x) {}\nreturn { json: { tenant: { business_id: e.business_id },\n  customer: { phone: e.phone, name: e.name },\n  customer_message: e.customer_message, ai_response: e.reply,\n  intent: 'general', sentiment_score: 0, escalated: false,\n  input_tokens: e.input_tokens, output_tokens: e.output_tokens,\n  cost_egp: cost, model: e.model, wa_message_id: e.wa_message_id } };"
