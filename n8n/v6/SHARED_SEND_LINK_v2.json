      "parameters": {
        "jsCode": "const i = $input.first().json;\nconst t = i.tenant || {};\nif (!t.business_id) throw new Error('Missing tenant.business_id');\nif (!i.customer_jid) throw new Error('Missing customer_jid');\nconst category = i.category || 'menu';\nconst defaults = {\n  menu: `🍽️ *تفضل المنيو يا فندم*\\n\\n{{LINK}}\\n\\nأي صنف يعجبك أنا هنا 🌹`,\n  catalog: `📦 *تفضل الكتالوج*\\n\\n{{LINK}}\\n\\nأي منتج تحب تعرف عنه أكتر؟ ✨`,\n  booking: `📅 *احجز موعدك الآن*\\n\\n{{LINK}}\\n\\nلو احتجت مساعدة في الحجز قولي 😊`,\n  payment: `💳 *رابط الدفع*\\n\\n{{LINK}}\\n\\nبعد الدفع ابعتلي صورة التأكيد 🌹`,\n  location: `📍 *موقعنا*\\n\\n{{LINK}}`,\n  other: `🔗 {{LINK}}`\n};\nconst tmpl = i.custom_message || defaults[category] || defaults.other;\nconst byName = i.link_name ? `&name=eq.${encodeURIComponent(i.link_name)}` : `&category=eq.${encodeURIComponent(category)}`;\nreturn { json: { business_id: t.business_id, instance_name: t.instance_name, customer_jid: i.customer_jid,\n  category, message_template: tmpl, link_filter: byName } };"
      },
