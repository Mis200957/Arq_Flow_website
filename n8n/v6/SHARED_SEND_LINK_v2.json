      "parameters": {
        "jsCode": "const p = $('PREPARE').first().json;\nconst rows = $input.all().map(x => x.json).filter(r => r && r.url);\nconst row = rows[0];\nif (!row) {\n  return { json: { ...p, link_found: false, final_message: 'عذراً، الرابط غير متاح حالياً. تواصل معنا مباشرة 🙏' } };\n}\nreturn { json: { ...p, link_found: true, link_url: row.url, final_message: p.message_template.replace('{{LINK}}', row.url) } };"
      },
