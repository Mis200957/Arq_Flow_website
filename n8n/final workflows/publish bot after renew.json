      "parameters": {
        "jsCode": "/* Reject any request without a valid platform HMAC signature.\n * Requires n8n env: ARQFLOW_HMAC_SECRET (+ NODE_FUNCTION_ALLOW_BUILTIN=crypto). */\nconst crypto = require('crypto');\nconst secret = $env.ARQFLOW_HMAC_SECRET || '';\nif (!secret) throw new Error('ARQFLOW_HMAC_SECRET not set in n8n environment');\nconst item = $input.first().json;\nconst body = item.body || {};\nconst headers = item.headers || {};\nconst provided = headers['x-arqflow-signature'] || headers['X-ArqFlow-Signature'] || '';\nconst expected = crypto.createHmac('sha256', secret).update(JSON.stringify(body)).digest('hex');\nconst a = Buffer.from(String(provided));\nconst b = Buffer.from(expected);\nif (a.length !== b.length || !crypto.timingSafeEqual(a, b)) {\n  throw new Error('Invalid X-ArqFlow-Signature — request rejected');\n}\nreturn $input.all();"
      },
      "id": "cccc2222-renew-4444-8888-hmac00000001",
      "name": "VALIDATE_HMAC",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        200,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "typeValidation": "loose",
            "version": 2
          },
          "conditions": [
