                "singleValue": true
              }
            },
            {
              "id": "r2",
              "leftValue": "={{ $json.body.workflow_id }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "cccc3333-renew-4444-8888-ifsuspend001",
      "name": "WAS_SUSPENDED?",
