    },
    {
      "parameters": {
        "jsCode": "const out=$input.first().json;const r=Array.isArray(out)?out[0]:out;const id=r&&r.id;const p=$('PREPARE').first().json;\nreturn {json:{success:!!id,reservation_id:id||null,check_in:p.check_in,check_out:p.check_out,\n message: id? ('تم استلام طلب الحجز ✅ رقم الحجز: '+id+' (بانتظار التأكيد)') : 'تعذّر إنشاء الحجز، حاول مرة أخرى.'}};"
      },
