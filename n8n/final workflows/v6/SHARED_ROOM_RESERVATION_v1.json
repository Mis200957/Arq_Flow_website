          "id": "arqflow_supabase",
          "name": "Supabase service_role"
        }
      },
      "alwaysOutputData": true,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const p=$('PREPARE').first().json;const c=$input.first().json;\nconst customer_id=Array.isArray(c)?(c[0]&&c[0].id):(c&&c.id);\nconst res_body={business_id:p.business_id,customer_id:customer_id||null,room_id:p.room_id,check_in:p.check_in,check_out:p.check_out,guests_count:p.guests_count,status:'pending',source:'whatsapp',notes:p.notes};\nreturn {json:{customer_id:customer_id||null,res_body}};"
      },
      "id": "f0321249-5c13-4429-a215-24c9c0c05811",
