    {
      "parameters": {
        "method": "GET",
        "url": "https://zjathejcdkpxjyvululp.supabase.co/rest/v1/messages?select=intent,sentiment_score,escalated,direction,created_at&business_id=eq.{{ $('PREPARE').first().json.business_id }}&customer_id=eq.{{ $('GET_CUSTOMER').first().json.id }}&order=created_at.desc&limit={{ $('PREPARE').first().json.history_limit }}",
        "options": {},
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "supabaseApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        }
      },
      "id": "0789ec07-0425-4aea-a696-be642415f38a",
      "name": "FETCH_MESSAGES",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        660,
        0
      ],
      "credentials": {
        "supabaseApi": {
          "id": "arqflow_supabase",
          "name": "Supabase service_role"
        }
      },
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const cust = $('GET_CUSTOMER').first().json;\nconst msgs = $input.all().map(x => x.json).filter(m => m && m.direction);\nconst tags = [];\nconst totalOrders = parseInt(cust.total_orders || 0);\nif (totalOrders >= 5) tags.push('regular_customer');\nif (totalOrders >= 15) tags.push('loyal_customer');\nconst spent = parseFloat(cust.total_spent_egp || 0);\nif (spent >= 5000) tags.push('high_value');\nconst scores = msgs.map(m => parseFloat(m.sentiment_score)).filter(n => !isNaN(n));\nconst avg = scores.length ? scores.reduce((a,b)=>a+b,0)/scores.length : 0;\nif (avg >= 1) tags.push('promoter');\nif (avg <= -1) tags.push('at_risk');\nconst complaints = msgs.filter(m => String(m.intent||'').toLowerCase().includes('complaint')).length;\nif (complaints >= 3) tags.push('frequent_complainer');\nconst esc = msgs.filter(m => m.escalated === true).length;\nif (esc >= 2) tags.push('needs_attention');\nconst inbound = msgs.filter(m => m.direction === 'inbound').length;\nif (inbound >= 25) tags.push('engaged');\nif (inbound >= 50) tags.push('super_engaged');\nif (cust.created_at) {\n  const d = (Date.now() - new Date(cust.created_at).getTime()) / 86400000;\n  if (d < 7) tags.push('new_customer');\n}\nif (cust.last_interaction_at) {\n  const d = (Date.now() - new Date(cust.last_interaction_at).getTime()) / 86400000;\n  if (d > 30) tags.push('inactive');\n  if (d > 90) tags.push('churned');\n}\nconst uniq = [...new Set(tags)];\nreturn { json: { customer_id: cust.id, tags: uniq, avg_sentiment: +avg.toFixed(2),\n  update_body: { tags: uniq, sentiment: +avg.toFixed(2), updated_at: new Date().toISOString() } } };"
      },
