        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const i = $input.first().json;\nconst t = i.tenant || {};\nif (!t.business_id) throw new Error('Missing tenant.business_id');\nconst phone = String((i.customer && i.customer.phone) || '').replace(/[^0-9]/g, '');\nif (!phone) throw new Error('Missing customer.phone');\nreturn { json: { business_id: t.business_id, phone, history_limit: i.history_limit || 100,\n  customer_body: { business_id: t.business_id, phone, channel: 'whatsapp' } } };"
      },
      "id": "baec448b-c3f4-478e-9ed9-bff08af8ee38",
      "name": "PREPARE",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
