        "jsonExample": "{\"tenant\": {\"business_id\": \"00000000-0000-0000-0000-000000000000\"}, \"customer\": {\"phone\": \"201234567890\"}, \"history_limit\": 100}"
      },
      "id": "0956569b-d0df-42ad-93cc-1508f9434e7b",
