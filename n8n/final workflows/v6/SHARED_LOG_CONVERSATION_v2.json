        "jsCode": "const p = $('PREPARE').first().json;\nconst cust = $('UPSERT_CUSTOMER').first().json;\nconst router = $('CONV_ROUTER').first().json;\nconst j = $json;\nconst conversation_id = j.id || router.conversation_id;\nreturn { json: {\n  business_id: p.business_id,\n  customer_id: cust.id,\n  conversation_id,\n  cost_egp: p.cost_egp,\n  inbound_body: { business_id: p.business_id, conversation_id, customer_id: cust.id, direction: 'inbound', content: p.customer_message, media_type: 'text', intent: p.intent, sentiment_score: p.sentiment_score, escalated: p.escalated, wa_message_id: p.wa_message_id, created_at: p.now },\n  outbound_body: { business_id: p.business_id, conversation_id, customer_id: cust.id, direction: 'outbound', content: p.ai_response, media_type: 'text', input_tokens: p.input_tokens, output_tokens: p.output_tokens, cost_egp: p.cost_egp, model: p.model, escalated: p.escalated, created_at: p.now },\n  bump_body: { last_message_at: p.now, message_count: (router.message_count_prev || 0) + 2, status: p.escalated ? 'escalated' : 'open' }\n} };"
