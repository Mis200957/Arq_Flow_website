    {
      "parameters": {
        "jsCode": "const i = $input.first().json;\nconst t = i.tenant || {};\nif (!t.business_id) throw new Error('Missing tenant.business_id');\nconst cust = i.customer || {};\nconst phone = String(cust.phone || i.customer_id || '').replace(/[^0-9]/g, '');\nif (!phone) throw new Error('Missing customer.phone');\nconst now = new Date().toISOString();\nconst customer_body = { business_id: t.business_id, phone, channel: 'whatsapp', last_interaction_at: now };\nif (cust.name) customer_body.name = cust.name;\nreturn { json: {\n  business_id: t.business_id,\n  phone,\n  now,\n  customer_message: i.customer_message || '',\n  ai_response: i.ai_response || '',\n  intent: i.intent || 'general',\n  sentiment_score: i.sentiment_score ?? 0,\n  escalated: i.escalated === true,\n  input_tokens: parseInt(i.input_tokens || 0),\n  output_tokens: parseInt(i.output_tokens || 0),\n  cost_egp: +(i.cost_egp || 0),\n  model: i.model || i.model_used || '',\n  wa_message_id: i.wa_message_id || null,\n  customer_body\n} };"
      },
