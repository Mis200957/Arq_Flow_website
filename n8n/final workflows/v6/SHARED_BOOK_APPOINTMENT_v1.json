    {
      "parameters": {
        "jsCode": "const out=$input.first().json;const r=Array.isArray(out)?out[0]:out;const id=r&&r.id;const p=$('PREPARE').first().json;\nreturn {json:{success:!!id,appointment_id:id||null,starts_at:p.starts_at,\n message: id? ('تم حجز الموعد بنجاح ✅ رقم الحجز: '+id) : 'تعذّر إنشاء الحجز، حاول مرة أخرى.'}};"
