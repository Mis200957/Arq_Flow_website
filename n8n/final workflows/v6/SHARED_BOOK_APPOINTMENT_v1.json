      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const p=$('PREPARE').first().json;const c=$input.first().json;\nconst customer_id=Array.isArray(c)?(c[0]&&c[0].id):(c&&c.id);\nconst appt_body={business_id:p.business_id,customer_id:customer_id||null,doctor_id:p.doctor_id,service_id:p.service_id,starts_at:p.starts_at,ends_at:p.ends_at,status:'scheduled',source:'whatsapp',notes:p.notes};\nreturn {json:{customer_id:customer_id||null,appt_body}};"
      },
      "id": "ce086e8a-4ed5-4225-acd4-5ed013e28de9",
