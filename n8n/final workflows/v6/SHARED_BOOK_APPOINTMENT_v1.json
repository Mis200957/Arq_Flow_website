    {
      "parameters": {
        "jsCode": "const i=$input.first().json;const t=i.tenant||{};\nif(!t.business_id) throw new Error('Missing tenant.business_id');\nconst phone=String(i.phone||'').replace(/[^0-9]/g,'');\nif(!phone) throw new Error('Missing phone');\nif(!i.starts_at) throw new Error('Missing starts_at');\nconst customer_body={business_id:t.business_id,phone,name:i.name||null,channel:'whatsapp'};\nreturn {json:{business_id:t.business_id,phone,starts_at:i.starts_at,ends_at:i.ends_at||null,doctor_id:i.doctor_id||null,service_id:i.service_id||null,notes:i.notes||null,customer_body}};"
      },
      "id": "8c03aefe-fb33-48cd-942a-201b33edecee",
      "name": "PREPARE",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        220,
        0
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://zjathejcdkpxjyvululp.supabase.co/rest/v1/customers?on_conflict=business_id,phone",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "supabaseApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
