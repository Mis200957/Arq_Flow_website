    {
      "parameters": {
        "jsCode": "const rows = $input.all().map(x => x.json).filter(m => m && m.content);\nif (rows.length === 0) {\n  return { json: { no_messages: true, summary: 'لا توجد محادثات سابقة', prompt_text: '' } };\n}\nconst ordered = rows.slice().reverse();\nconst formatted = ordered.map(m => (m.direction === 'inbound' ? 'العميل: ' : 'البوت: ') + String(m.content||'').slice(0,200)).join('\\n');\nconst prompt_text = `لخص المحادثة دي في 200 كلمة بحد أقصى. ركز على:\\n1. النقاط الأساسية اللي العميل اتكلم فيها\\n2. الطلبات أو الشكاوى لو في\\n3. حالة العميل العامة (راضي، عصبي، عادي)\\n4. أي تفاصيل مهمة (مواعيد، أسعار، عناوين)\\n\\nاكتب الملخص بالعربي. ابدأ مباشرة بدون مقدمة.\\n\\nالمحادثة:\\n${formatted}`;\nreturn { json: { no_messages: false, message_count: rows.length, prompt_text } };"
      },
