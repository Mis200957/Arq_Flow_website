    {
      "parameters": {
        "jsCode": "const ai = $input.first().json;\nlet s = '';\nif (typeof ai.output === 'string') s = ai.output;\nelse if (ai.text) s = ai.text;\nelse if (ai.output && ai.output[0] && ai.output[0].content && ai.output[0].content[0]) s = ai.output[0].content[0].text || '';\nelse if (ai.choices && ai.choices[0]) s = ai.choices[0].message.content || '';\ns = String(s).trim().slice(0, 1500);\nreturn { json: { summary: s, update_body: { conversation_summary: s, updated_at: new Date().toISOString() } } };"
      },
