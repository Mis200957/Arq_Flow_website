    {
      "parameters": {
        "jsCode": "const messages = $input.all().map(i => i.json);\nconst ctx = $('SUMMARIZE_PREPARE').first().json;\n\nif (messages.length === 0) {\n  return { json: { ...ctx, summary: 'لا توجد محادثات سابقة', no_messages: true } };\n}\n\nconst formatted = messages.slice(-20).map(m => {\n  const time = m['Timestamp'] || '?';\n  const userMsg = (m['Customer Message'] || '').slice(0, 150);\n  const botMsg = (m['AI Response'] || '').slice(0, 150);\n  return `[${time}]\\nالعميل: ${userMsg}\\nالبوت: ${botMsg}`;\n}).join('\\n\\n');\n\nconst promptText = `لخص المحادثة دي في 200 كلمة بحد أقصى. ركز على:\n1. النقاط الأساسية اللي العميل اتكلم فيها\n2. الطلبات أو الشكاوى لو في\n3. حالة العميل العامة (راضي، عصبي، عادي)\n4. أي تفاصيل مهمة (مواعيد، أسعار، عناوين)\n\nاكتب الملخص بالعربي. ابدأ مباشرة بدون مقدمة.\n\nالمحادثة:\n${formatted}`;\n\nreturn {\n  json: {\n    ...ctx,\n    prompt_text: promptText,\n    message_count: messages.length,\n    no_messages: false\n  }\n};"
      },
      "id": "5e80bfbf-7840-454c-a17c-1f811288a6d6",
      "name": "BUILD_SUMMARY_PROMPT",
