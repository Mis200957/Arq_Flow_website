          "name": "فاروق"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const aiOutput = $input.first().json;\nconst ctx = $('BUILD_SUMMARY_PROMPT').first().json;\n\nlet summary = '';\nif (typeof aiOutput.output === 'string') summary = aiOutput.output;\nelse if (aiOutput.text) summary = aiOutput.text;\nelse if (aiOutput.choices?.[0]?.message?.content) summary = aiOutput.choices[0].message.content;\n\nsummary = summary.trim().slice(0, 1500);\n\nreturn {\n  json: {\n    tenant: ctx.tenant,\n    customer_id: ctx.customer_id,\n    summary: summary,\n    summarized_at: new Date().toISOString().slice(0,19).replace('T', ' '),\n    message_count: ctx.message_count\n  }\n};"
      },
